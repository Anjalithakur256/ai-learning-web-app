{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run local web server",
			"type": "shell",
			"command": "node",
			"args": [
				"server.js"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"isBackground": true,
			"problemMatcher": {
				"owner": "node-server",
				"pattern": {
					"regexp": "NEVER_MATCH"
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "Local Dev Server",
					"endsPattern": "localhost:"
				}
			},
			"group": "build"
		}
	]
}